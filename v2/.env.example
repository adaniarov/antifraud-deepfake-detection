# Copy to repo-root `.env` or `v2/.env` (both are gitignored).
# `python-dotenv` in notebooks loads repo-root `.env` first, then `v2/.env`.

# Native OpenAI API — notebook 11_mass_generation_openai.ipynb
OPENAI_API_KEY=

# OpenRouter — notebook 12_mass_generation_mistral.ipynb (Mistral, seen generator B)
# Ключ №1 (отдельный проект/ключ под Mistral на OpenRouter).
OPENROUTER_API_KEY_MISTRAL=

# OpenRouter — notebook 13_mass_generation_claude_openrouter.ipynb (Claude holdout, test only)
# Ключ №2 (отдельный проект/ключ под Claude на OpenRouter). Не смешивать с MISTRAL-ключом.
OPENROUTER_API_KEY_CLAUDE=

# Доля seen-сетки для OpenAI в ноутбуках 11 и 12 (0.0–1.0). Остаток — Mistral. В ноутбуках по умолчанию 0.6 (60/40 GPT/Mistral).
OPENAI_SEEN_SHARE=0.6

# Параллельные запросы к API на один lane (ноутбуки 11–13). При 429 уменьшите (например 4) или поставьте 1.
LLM_GEN_MAX_WORKERS=8

# Устарело: нативный Mistral API (если вернёте notebook 12 на api.mistral.ai)
# MISTRAL_API_KEY=
